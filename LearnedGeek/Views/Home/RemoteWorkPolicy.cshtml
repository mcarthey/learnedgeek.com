@{
    ViewData["Title"] = "Remote & Hybrid Work Policy";
}

<div class="bg-white dark:bg-neutral-900 transition-colors">
    <!-- Header -->
    <section class="py-24 lg:py-32 border-b border-neutral-200 dark:border-neutral-700">
        <div class="max-w-4xl mx-auto px-6 lg:px-8">
            <span class="text-xs font-semibold text-neutral-400 dark:text-neutral-500 uppercase tracking-widest">
                Policy
            </span>
            <h1 class="mt-4 text-4xl md:text-5xl font-semibold text-neutral-900 dark:text-white leading-tight">
                Remote &amp; Hybrid Work Policy
            </h1>
            <p class="mt-6 text-neutral-500 dark:text-neutral-400">
                Learned Geek LLC &mdash; Effective March 2026
            </p>
        </div>
    </section>

    <!-- Content -->
    <section class="py-16 lg:py-24">
        <div class="max-w-4xl mx-auto px-6 lg:px-8">
            <div class="prose prose-neutral dark:prose-invert max-w-none">

                <h2>Purpose</h2>
                <p>
                    This policy establishes guidelines for remote and hybrid work arrangements at
                    <strong>Learned Geek LLC</strong>. We support flexible work arrangements that enable
                    productivity while maintaining the security, collaboration, and accountability standards
                    our clients and projects require.
                </p>

                <h2>Scope</h2>
                <p>This policy applies to all personnel working under Learned Geek LLC:</p>
                <ul>
                    <li><strong>Full-time employees</strong></li>
                    <li><strong>Part-time employees</strong></li>
                    <li><strong>Contractors</strong></li>
                    <li><strong>Interns</strong></li>
                </ul>
                <p>
                    Access levels, schedule expectations, and device requirements may differ by role.
                    Specific terms will be outlined in individual offer letters or contractor agreements.
                </p>

                <h2>Work Arrangement Types</h2>

                <h3>Hybrid</h3>
                <p>
                    The default arrangement for most roles. Hybrid workers split time between on-site
                    and remote work. Specific in-office days or minimum on-site requirements (if any)
                    are defined per role and communicated during onboarding.
                </p>

                <h3>Fully Remote</h3>
                <p>
                    Available for roles where physical presence is not required. Fully remote workers
                    must maintain availability during core business hours and attend scheduled meetings
                    via video conference.
                </p>

                <h3>On-Site</h3>
                <p>
                    Required for roles involving physical infrastructure, lab equipment, or client-facing
                    obligations that cannot be performed remotely.
                </p>

                <h2>Schedule &amp; Availability</h2>
                <ul>
                    <li><strong>Core hours:</strong> 9:00 AM &ndash; 3:00 PM Central Time. All personnel should be reachable during core hours on scheduled work days.</li>
                    <li><strong>Flexibility:</strong> Start and end times outside core hours are flexible, subject to project needs and manager approval.</li>
                    <li><strong>Meetings:</strong> All scheduled meetings (team standups, client calls, 1:1s) are expected to be attended on time, whether in-person or remote.</li>
                    <li><strong>Communication:</strong> Remote workers must be responsive on company communication channels (email, Teams/Slack) during working hours.</li>
                </ul>

                <h2>Network Access &amp; VPN</h2>
                <p>
                    Learned Geek LLC maintains a managed network infrastructure with VPN access for
                    remote workers. The following rules apply:
                </p>
                <ul>
                    <li><strong>VPN required:</strong> All access to internal company systems, file servers, development environments, and client resources must go through the company VPN.</li>
                    <li><strong>Domain authentication:</strong> VPN access is authenticated using your company email credentials. Do not share your credentials with anyone.</li>
                    <li><strong>Network segmentation:</strong> Access is role-based. Interns and contractors may have access limited to specific network segments appropriate to their role and project assignments.</li>
                    <li><strong>Public Wi-Fi:</strong> If you must use public Wi-Fi (coffee shops, airports, etc.), the VPN must be active before accessing any company resources. No exceptions.</li>
                    <li><strong>Access revocation:</strong> VPN and network access will be revoked immediately upon termination, end of contract, or end of internship.</li>
                </ul>

                <h2>Device Policy</h2>

                <h3>Company-Provided Devices</h3>
                <p>
                    When a company device is provided, it is the primary device for all work activities.
                    Company devices are managed, updated, and secured by Learned Geek LLC. Do not install
                    unauthorized software or disable security features.
                </p>

                <h3>Personal Devices (BYOD)</h3>
                <p>
                    When personal devices are used for work (common for interns and some contractors),
                    the following conditions apply:
                </p>
                <ul>
                    <li>The device must run a current, supported operating system with security updates applied</li>
                    <li>Full-disk encryption must be enabled</li>
                    <li>A screen lock with password/biometric authentication must be active</li>
                    <li>Antivirus/antimalware software must be installed and current</li>
                    <li>Company data must not be stored on personal cloud storage (Google Drive, Dropbox, etc.) unless explicitly authorized</li>
                </ul>

                <h2>Data Security &amp; Acceptable Use</h2>
                <ul>
                    <li><strong>Confidentiality:</strong> Company and client data accessed remotely is subject to the same confidentiality obligations as on-site work. Do not share, copy, or transfer company data to personal accounts or unauthorized systems.</li>
                    <li><strong>Source code:</strong> Code repositories must only be accessed through authorized accounts. Do not clone repositories to unauthorized devices.</li>
                    <li><strong>Client data:</strong> If your role involves access to client systems or data, follow the client's security requirements in addition to this policy.</li>
                    <li><strong>Physical security:</strong> When working remotely, ensure your screen is not visible to unauthorized persons. Lock your device when stepping away.</li>
                    <li><strong>Incident reporting:</strong> Report any suspected security incident (lost device, unauthorized access, phishing attempt) to management immediately.</li>
                </ul>

                <h2>Role-Specific Access Levels</h2>

                <table>
                    <thead>
                        <tr>
                            <th>Role</th>
                            <th>Network Access</th>
                            <th>VPN</th>
                            <th>Source Code</th>
                            <th>Client Systems</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Employee</td>
                            <td>Full internal network</td>
                            <td>Yes</td>
                            <td>Full</td>
                            <td>As assigned</td>
                        </tr>
                        <tr>
                            <td>Contractor</td>
                            <td>Project-specific segment</td>
                            <td>Yes</td>
                            <td>Project repos only</td>
                            <td>As contracted</td>
                        </tr>
                        <tr>
                            <td>Intern</td>
                            <td>Limited segment</td>
                            <td>Yes</td>
                            <td>Assigned repos only</td>
                            <td>No</td>
                        </tr>
                    </tbody>
                </table>

                <h2>Workspace Requirements</h2>
                <p>Remote workers are expected to maintain a workspace that supports productive work:</p>
                <ul>
                    <li>Reliable internet connection sufficient for video calls and VPN usage</li>
                    <li>A reasonably quiet environment for meetings and focused work</li>
                    <li>A workspace where confidential information is not exposed to unauthorized persons</li>
                </ul>
                <p>
                    We understand that home environments vary. If you have temporary disruptions (construction,
                    family obligations, internet outage), communicate proactively with your manager.
                </p>

                <h2>Internship-Specific Provisions</h2>
                <p>
                    Interns working remotely should be aware of the following additional guidelines:
                </p>
                <ul>
                    <li><strong>Supervision:</strong> Interns will have a designated supervisor and regular check-ins (at minimum weekly) to review progress, answer questions, and provide mentorship.</li>
                    <li><strong>Onboarding:</strong> Remote interns will receive a structured onboarding that includes VPN setup, tool access, project orientation, and security training.</li>
                    <li><strong>Access scope:</strong> Intern network and repository access is limited to assigned project work. Access will be reviewed and adjusted as projects change.</li>
                    <li><strong>Duration:</strong> VPN and system access is tied to the internship period defined in the offer letter. Access is revoked on the last day of the internship.</li>
                </ul>

                <h2>Policy Violations</h2>
                <p>
                    Violations of this policy may result in disciplinary action, up to and including
                    termination of employment, contract, or internship. Serious security violations
                    (data breach, credential sharing, unauthorized access) will be addressed immediately
                    and may involve revocation of all remote access pending investigation.
                </p>

                <h2>Policy Updates</h2>
                <p>
                    This policy may be updated as our infrastructure, team, and business needs evolve.
                    Changes will be communicated to all affected personnel and posted on this page with
                    an updated effective date.
                </p>

                <h2>Questions</h2>
                <p>
                    If you have questions about this policy or need clarification about your specific
                    access level or work arrangement, contact us:
                </p>
                <p>
                    <strong>Learned Geek LLC</strong><br />
                    Email: <a href="mailto:mark@learnedgeek.com">mark@learnedgeek.com</a>
                </p>

                <hr class="my-8" />

                <p class="text-sm text-neutral-500">
                    See also: <a asp-action="Privacy">Privacy Policy</a> |
                    <a asp-action="Services">Services</a>
                </p>

            </div>
        </div>
    </section>
</div>
